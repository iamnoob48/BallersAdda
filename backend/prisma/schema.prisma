generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   Int            @id @default(autoincrement())
  email                String         @unique
  username             String?
  password             String?
  phone                String?        @unique
  profilePic           String?
  role                 Role           @default(PLAYER)
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  googleId             String?        @unique
  isVerified           Boolean        @default(false)
  lastLogin            DateTime?
  status               UserStatus     @default(ACTIVE)
  academy              Academy?
  coach                Coach?
  playerProfile        PlayerProfile?
  organizedTournaments Tournament[]   @relation("OrganizedTournaments")

  @@index([email, role])
}

model PlayerProfile {
  id                Int                @id @default(autoincrement())
  firstName         String
  lastName          String
  age               Int?
  gender            String?
  height            Float?
  weight            Float?
  position          String?
  tournamentsPlayed Int?               @default(0)
  academyJoinDate   DateTime?
  academyId         Int?
  badges            Int?               @default(0)
  bio               String?
  createdAt         DateTime           @default(now())
  displayName       String?
  dominantFoot      String?
  experienceLevel   ExperienceLevel?   @default(BEGINNER)
  nationalRank      Int?
  regionalRank      Int?
  updatedAt         DateTime           @updatedAt
  tournamentRatings Float?             @default(0.0)
  trainingRatings   Float?             @default(0.0)
  userId            Int                @unique
  academy           Academy?           @relation(fields: [academyId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  tournaments       PlayerTournament[]
  teams             Team[]             @relation("PlayerProfileToTeam")
  attendances       SessionAttendance[]
  academyStats      PlayerAcademyStats[]

  @@index([academyId])
  @@index([tournamentRatings])
}

model Tournament {
  id                   Int                @id @default(autoincrement())
  tournamentUid        String             @unique @default(cuid())
  name                 String
  description          String?
  location             String
  startDate            DateTime
  endDate              DateTime
  price                Decimal
  category             String
  registrationFee      Decimal
  registrationDeadline DateTime
  maxTeams             Int?
  maxPlayersPerTeam    Int?
  status               Status             @default(UPCOMING)
  organizerId          Int?
  isPublic             Boolean            @default(true)
  venueImage           String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  players              PlayerTournament[]
  teams                Team[]
  matches              Match[]
  organizer            User?              @relation("OrganizedTournaments", fields: [organizerId], references: [id])

  @@index([status])
  @@index([location])
}

model PlayerTournament {
  id           Int           @id @default(autoincrement())
  playerId     Int
  tournamentId Int
  goals        Int?          @default(0)
  assists      Int?          @default(0)
  yellowCards  Int?          @default(0)
  redCards     Int?          @default(0)
  rating       Float?        @default(0.0)
  joinedAt     DateTime      @default(now())
  teamId       Int?
  player       PlayerProfile @relation(fields: [playerId], references: [id])
  team         Team?         @relation(fields: [teamId], references: [id])
  tournament   Tournament    @relation(fields: [tournamentId], references: [id])

  @@unique([playerId, tournamentId])
  @@index([tournamentId])
}

model Team {
  id                Int                @id @default(autoincrement())
  name              String
  coachName         String?
  logoUrl           String?
  tournamentId      Int
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  coachId           Int?
  tournamentPlayers PlayerTournament[]
  coach             Coach?             @relation(fields: [coachId], references: [id])
  tournament        Tournament         @relation(fields: [tournamentId], references: [id])
  players           PlayerProfile[]    @relation("PlayerProfileToTeam")

  @@index([tournamentId])
}

model Academy {
  id               Int               @id @default(autoincrement())
  academyLogoURL   String?
  name             String
  description      String?
  country          String?
  city             String?
  address          String?
  state            String?
  pinCode          String?
  licenseNo        String?           @unique
  verified         Boolean           @default(false)
  noOfStudents     Int?
  contactEmail     String?           @unique
  contactPhone     String?           @unique
  establishedAt    DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  rating           Float?            @default(0.0)
  detailedInfo     String?
  primaryPictureId Int?              @unique
  userId           Int?               @unique
  primaryPicture   AcademyPicture?   @relation("PrimaryPicture", fields: [primaryPictureId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  pictures         AcademyPicture[]
  pricingPlans     AcademyPlan[]
  schedules        AcademySchedule[]
  coaches          Coach[]
  players          PlayerProfile[]
  sessions         AcademySession[]
  matches          Match[]
  playerStats      PlayerAcademyStats[]
  invites          AcademyInvite[]

  @@index([name])
}

model AcademySchedule {
  id        Int      @id @default(autoincrement())
  academyId Int
  dayOfWeek String
  isActive  Boolean  @default(false)
  startTime String?
  endTime   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  academy   Academy  @relation(fields: [academyId], references: [id])
}

model AcademyPlan {
  id           Int          @id @default(autoincrement())
  academyId    Int
  slug         String       @unique
  title        String
  description  String?
  priceCents   Int
  currency     String       @default("INR")
  billingCycle BillingCycle
  features     Json?
  isDefault    Boolean      @default(false)
  recommended  Boolean      @default(false)
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  academy      Academy      @relation(fields: [academyId], references: [id])

  @@index([academyId])
}

model AcademyPicture {
  id                Int       @id @default(autoincrement())
  academyId         Int
  pictureURL        String
  publicId          String?
  provider          String?
  altText           String?
  caption           String?
  width             Int?
  height            Int?
  contentType       String?
  sizeInBytes       Int?
  sortOrder         Int?      @default(0)
  isPrimary         Boolean   @default(false)
  metadata          Json?
  isActive          Boolean   @default(true)
  deletedAt         DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  primaryForAcademy Academy?  @relation("PrimaryPicture")
  academy           Academy   @relation(fields: [academyId], references: [id], onDelete: Cascade)

  @@index([academyId])
  @@index([academyId, isPrimary])
}

model Coach {
  id              Int      @id @default(autoincrement())
  profilePicLogo  String?
  firstName       String
  lastName        String
  bio             String?
  coachEmail      String?  @unique
  experienceYears Int?
  certifications  String?
  academyId       Int?
  coachLicenceNo  String?  @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          Int      @unique
  academy         Academy? @relation(fields: [academyId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
  teams           Team[]

  @@index([academyId])
}

model AcademySession {
  id         Int                 @id @default(autoincrement())
  date       DateTime            @default(now())
  type       String              @default("TRAINING")
  academyId  Int
  academy    Academy             @relation(fields: [academyId], references: [id])
  attendance SessionAttendance[]

  @@index([academyId])
  @@index([date])
}

model SessionAttendance {
  id        Int            @id @default(autoincrement())
  isPresent Boolean        @default(true)
  sessionId Int
  session   AcademySession @relation(fields: [sessionId], references: [id])
  playerId  Int
  player    PlayerProfile  @relation(fields: [playerId], references: [id])

  @@unique([sessionId, playerId])
  @@index([playerId])
}

model Match {
  id           Int       @id @default(autoincrement())
  date         DateTime  @default(now())
  matchType    MatchType @default(OFFICIAL_TOURNAMENT)
  
  tournamentId Int?
  tournament   Tournament? @relation(fields: [tournamentId], references: [id])
  
  academyId    Int?
  academy      Academy?    @relation(fields: [academyId], references: [id])
}

model PlayerAcademyStats {
  id                Int           @id @default(autoincrement())
  
  officialCaps      Int           @default(0) 
  officialGoals     Int           @default(0)
  officialAssists   Int           @default(0)
  officialMotm      Int           @default(0) 
  officialAvgRating Float         @default(0.0)

  practiceMatches   Int           @default(0) 
  practiceGoals     Int           @default(0)
  practiceAssists   Int           @default(0)
  practiceMotm      Int           @default(0) 
  practiceAvgRating Float         @default(0.0)
  
  playerId          Int
  player            PlayerProfile @relation(fields: [playerId], references: [id])
  
  academyId         Int
  academy           Academy       @relation(fields: [academyId], references: [id])

  @@unique([playerId, academyId])
  @@index([playerId])
  @@index([academyId])
}

enum MatchType {
  OFFICIAL_TOURNAMENT
  INTERNAL_PRACTICE
}

enum Role {
  PLAYER
  ACADEMY
  COACH
  SCOUT
  ADMIN
}

enum Status {
  UPCOMING
  ONGOING
  COMPLETED
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum ExperienceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  PRO
}

enum BillingCycle {
  MONTH
  YEAR
  SESSION
}

// THE HOLDING AREA
model AcademyInvite {
  id        Int      @id @default(autoincrement())
  email     String   
  role      Role     @default(COACH)
  status    String   @default("PENDING") // PENDING, ACCEPTED
  
  academyId Int
  academy   Academy  @relation(fields: [academyId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())

  @@unique([email, academyId]) 
}
